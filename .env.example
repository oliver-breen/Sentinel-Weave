# ──────────────────────────────────────────────────────────────────────────────
# SentinelWeave — environment variable template
#
# Copy this file to .env and fill in real values to enable optional features.
# The .env file is intentionally git-ignored — never commit real secrets.
#
#   cp .env.example .env
#   # edit .env with your credentials
#   docker compose up --build
# ──────────────────────────────────────────────────────────────────────────────

# ── Azure Blob Storage (encrypted report persistence) ─────────────────────────
# Used by: sentinel_weave.azure_integration.BlobStorageClient
AZURE_STORAGE_CONNECTION_STRING=

# ── Azure Cognitive Services Text Analytics (NLP log enrichment) ──────────────
# Used by: sentinel_weave.azure_integration.TextAnalyticsClient
AZURE_TEXT_ANALYTICS_ENDPOINT=
AZURE_TEXT_ANALYTICS_KEY=

# ── Azure Application Insights (telemetry) ────────────────────────────────────
# Used by: sentinel_weave.azure_integration.SecurityTelemetry
AZURE_APPINSIGHTS_CONNECTION_STRING=

# ── Azure ML endpoint (optional remote threat scoring) ────────────────────────
# Used by: sentinel_weave.threat_detector.ThreatDetector
SENTINELWEAVE_AZURE_ENDPOINT=
SENTINELWEAVE_AZURE_API_KEY=
